# DataForSEO (keyword research)
# Sign up at https://dataforseo.com
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password

# Google Sheets (topic queue)
# See README for setup instructions
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json
GOOGLE_SHEET_ID=your_google_sheet_id

# Gemini (image generation)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# SMTP (sending review emails)
SMTP_HOST=your.mail.server
SMTP_PORT=465
SMTP_USER=pipeline@yoursite.com
SMTP_PASS=your_password

# Review recipient
REVIEW_EMAIL_TO=reviewer@example.com
REVIEW_EMAIL_FROM=pipeline@yoursite.com

# WalterWrites (content humanization, optional)
# Connect via the WalterWrites MCP server — no credentials needed here.
# See "Optional: WalterWrites Humanization" in README.md.
